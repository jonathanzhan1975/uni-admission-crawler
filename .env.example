# 高校招生动态聚合推送系统 - Secrets 模板
# 复制此文件为 .env 并填入真实值
# .env 文件已在 .gitignore 中，不会被提交

# 飞书群机器人 Webhook URL
# 获取方式：飞书群 → 设置 → 群机器人 → 添加机器人 → 自定义机器人 → 复制 Webhook 地址
LARK_WEBHOOK_URL=

# Server 酱 SendKey
# 获取方式：https://sct.ftqq.com → GitHub 登录 → SendKey 页面
SERVERCHAN_SENDKEY=

# Google AI Studio API Key（用于清华源的 LLM 分类，Gemini Flash）
# 获取方式：https://aistudio.google.com/apikey → Create API Key
GOOGLE_API_KEY=
